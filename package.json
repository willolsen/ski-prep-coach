{
  "name": "ski-prep-coach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SkiPrepCoach closed-loop coaching engine",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "sync:exercises": "tsx scripts/sync-exercise-db.ts",
    "gallery:exercises": "tsx scripts/generate-exercise-gallery.ts",
    "mock:server": "tsx watch scripts/mock-server.ts",
    "generate:images": "tsx --env-file=.env scripts/generate-exercise-images.ts",
    "db:migrate": "tsx --env-file=.env db/migrate.ts",
    "db:seed": "tsx --env-file=.env db/seed.ts",
    "backfill:history": "tsx --env-file=.env scripts/backfill-history.ts",
    "pretest": "npm run db:migrate && npm run db:seed",
    "test": "tsx --env-file=.env --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.27",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
