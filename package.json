{
  "name": "ski-prep-coach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SkiPrepCoach closed-loop coaching engine",
  "scripts": {
    "sync:exercises": "tsx scripts/sync-exercise-db.ts",
    "gallery:exercises": "tsx scripts/generate-exercise-gallery.ts",
    "db:migrate": "tsx --env-file=.env db/migrate.ts",
    "db:seed": "tsx --env-file=.env db/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
